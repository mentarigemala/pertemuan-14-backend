{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "moduleResolution": "node16",

    "resolveJsonModule": true,

    "types": ["node"]
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist"
  ]
}